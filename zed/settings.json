// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^cat\\b"
            },
            {
              "pattern": "^ls\\b"
            },
            {
              "pattern": "^pwd\\b"
            },
            {
              "pattern": "^rg\\b"
            },
            {
              "pattern": "^find\\b"
            },
            {
              "pattern": "^head\\b"
            },
            {
              "pattern": "^tail\\b"
            },
            {
              "pattern": "^wc\\b"
            },
            {
              "pattern": "^stat\\b"
            },
            {
              "pattern": "^file\\b"
            },
            {
              "pattern": "^sed\\s+-n\\b"
            },
            {
              "pattern": "^awk\\b"
            },
            {
              "pattern": "^git\\s+(status|diff|show|log|fetch|ls-files|branch|remote\\s+-v|grep|rev-parse|describe)\\b"
            },
            {
              "pattern": "^gh\\s+(version|auth\\s+status|repo\\s+view|pr\\s+(status|view|list)|issue\\s+(list|view)|alias\\s+list)\\b"
            }
          ]
        }
      }
    }
  },
  "autosave": "off",
  "base_keymap": "VSCode",
  "buffer_font_fallbacks": ["Nerd Font"],
  "buffer_font_family": "CaskaydiaCove Nerd Font",
  "buffer_font_size": 14,
  "colorize_brackets": true,
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  },
  "cursor_blink": false,
  "git_panel": {
    "sort_by_path": true,
    "tree_view": true
  },
  "icon_theme": "Material Icon Theme",
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "closureReturnTypeHints": {
            "enable": "always"
          },
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true
          },
          "maxLength": null
        },
        "rust": {
          "analyzerTargetDir": true
        }
      }
    }
  },
  "relative_line_numbers": "enabled",
  "scroll_beyond_last_line": "off",
  "scrollbar": {
    "show": "never"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "button": false,
    "font_fallbacks": ["Nerd Font Mono"],
    "font_family": "CaskaydiaCove Nerd Font Mono",
    "font_size": 14,
    "line_height": "standard",
    "shell": "system",
    "working_directory": "current_project_directory"
  },
  "theme": "VSCode Dark Modern",
  "ui_font_size": 16,
  "vertical_scroll_margin": 0,
  "vim_mode": true
}
